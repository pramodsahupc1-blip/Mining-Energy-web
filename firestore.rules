rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isOwnerOrAdmin(userId) {
      return isOwner(userId) || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwnerOrAdmin(userId);
      // Only admins can create or update users (for security, or we allow create on auth)
      // Actually we need to allow create if it's the user themselves, but we must protect role
      allow create: if isOwner(userId) && (!("role" in request.resource.data) || request.resource.data.role == "user");
      allow update: if isOwner(userId) && (!("role" in request.resource.data.diff(resource.data).affectedKeys())) || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /wallets/{userId} {
      allow read: if isOwnerOrAdmin(userId);
      allow write: if isAdmin();
    }
    
    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /investments/{investmentId} {
      allow read: if isOwnerOrAdmin(resource.data.userId);
      allow create: if isOwnerOrAdmin(request.resource.data.userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /transactions/{transactionId} {
      allow read: if isOwnerOrAdmin(resource.data.userId);
      allow create: if isOwnerOrAdmin(request.resource.data.userId);
      allow update, delete: if isAdmin();
    }
    
    match /recharges/{rechargeId} {
      allow read: if isOwnerOrAdmin(resource.data.userId);
      allow create: if isOwnerOrAdmin(request.resource.data.userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /withdrawals/{withdrawalId} {
      allow read: if isOwnerOrAdmin(resource.data.userId);
      allow create: if isOwnerOrAdmin(request.resource.data.userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /tickets/{ticketId} {
      allow read: if isOwnerOrAdmin(resource.data.userId);
      allow create: if isOwnerOrAdmin(request.resource.data.userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
      
      match /messages/{messageId} {
        // Need to get the parent ticket to check ownership
        function getTicket() {
          return get(/databases/$(database)/documents/tickets/$(ticketId)).data;
        }
        allow read: if isOwnerOrAdmin(getTicket().userId);
        allow create: if isOwnerOrAdmin(getTicket().userId) && 
                      request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }
    
    match /notifications/{notificationId} {
      allow read: if isOwnerOrAdmin(resource.data.userId);
      allow create: if isAdmin();
      // Allow user to mark as read
      allow update: if isOwnerOrAdmin(resource.data.userId) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isAdmin();
    }
  }
}
